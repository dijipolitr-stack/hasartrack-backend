# HasarTrack Backend — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env

# ── SUNUCU ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development         # production | development

# ── VERİTABANI ────────────────────────────────────────────────
# Yerel geliştirme:
DATABASE_URL=postgresql://hasartrack:gizli_sifre@localhost:5432/hasartrack_db

# Production (DigitalOcean Managed DB / Railway / Render):
# DATABASE_URL=postgresql://user:pass@host:25060/hasartrack_db?sslmode=require

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=buraya_cok_uzun_ve_rastgele_bir_string_yazin_min_64_karakter
JWT_EXPIRES=8h

# ── FRONTEND ─────────────────────────────────────────────────
FRONTEND_URL=https://dijipolitr-stack.github.io   # CORS için

# ── DOSYA DEPOLAMA (AWS S3 veya Cloudflare R2) ───────────────
STORAGE_PROVIDER=s3          # s3 | local
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=eu-central-1
AWS_BUCKET=hasartrack-files

# ── SMS (Türk SMS Sağlayıcıları) ─────────────────────────────
SMS_PROVIDER=netgsm          # netgsm | iletimerkezi | disabled
NETGSM_KULLANICI_ADI=5XXXXXXXXX
NETGSM_SIFRE=xxxxxxxxxx
NETGSM_BASLIK=HasarTrack     # Gönderici adı

# ── E-POSTA (Opsiyonel) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@hasartrack.com
SMTP_PASS=xxxxxxxxxx
